{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nameOverride": {
      "description": "Partially override `spark-operator.fullname` template.",
      "type": "string"
    },
    "fullnameOverride": {
      "description": "Override release name.",
      "type": "string"
    },
    "commonLabels": {
      "description": "Common labels to add to resources.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "registry": {
          "description": "Image registry.",
          "type": "string",
          "default": "docker.io"
        },
        "repository": {
          "description": "Image repository.",
          "type": "string",
          "default": "kubeflow/spark-operator"
        },
        "tag": {
          "description": "Image tag.",
          "type": "string"
        },
        "pullPolicy": {
          "description": "Image pull policy.",
          "type": "string",
          "default": "IfNotPresent"
        },
        "pullSecrets": {
          "description": "Image pull secrets.",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "controller": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "default": 1
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "error"
          ],
          "default": "info"
        },
        "workers": {
          "type": "integer",
          "default": 10
        },
        "uiService": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "ingressUrlFormat": {
          "type": "string"
        },
        "batchScheduler": {
          "enable": {
            "description": "Specifies whether to enable batch scheduler for spark jobs scheduling.",
            "type": "boolean",
            "default": false
          }
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "description": "Specifies whether to create a service account for the controller.",
              "type": "boolean",
              "default": true
            },
            "name": {
              "description": "Optional name for the controller service account.",
              "type": "string"
            },
            "annotations": {
              "description": "Optional annotations for the controller service account.",
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "rbac": {
          "type": "object",
          "properties": {
            "create": {
              "description": "Specifies whether to create RBAC resources for the controller.",
              "type": "boolean",
              "default": true
            },
            "annotations": {
              "description": "Optional annotations for the controller RBAC resources.",
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "labels": {
          "description": "Extra labels for controller pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "description": "Extra annotations for controller pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "env": {
          "description": "Environment variables for controller containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "envFrom": {
          "description": "Environment variable sources for controller containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "volumeMounts": {
          "description": "Volume mounts for controller containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "securityContext": {
          "description": "Security context for controller containers.",
          "type": "object"
        },
        "sidecars": {
          "description": "Sidecar containers for controller pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "volumes": {
          "description": "Volumes for controller pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "nodeSelector": {
          "description": "Node selector for controller pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "affinity": {
          "description": "Affinity for controller pods.",
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "tolerations": {
          "description": "List of node taints to tolerate for controller pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "priorityClassName": {
          "description": "Priority class for controller pods.",
          "type": "string"
        },
        "resources": {
          "description": "Pod resource requests and limits for controller pods.",
          "type": "object"
        },
        "podSecurityContext": {
          "description": "Security context for controller pods.",
          "type": "object"
        }
      }
    },
    "webhook": {
      "type": "object",
      "properties": {
        "replicaCount": {
          "type": "integer",
          "default": 1
        },
        "logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "error"
          ],
          "default": "info"
        },
        "port": {
          "type": "integer",
          "default": 9443
        },
        "portName": {
          "type": "string",
          "default": "webhook"
        },
        "failurePolicy": {
          "type": "string",
          "enum": [
            "Fail",
            "Ignore"
          ],
          "default": "Fail"
        },
        "timeoutSeconds": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 30
        },
        "resourceQuotaEnforcement": {
          "properties": {
            "enable": {
              "description": "Whether to enable the ResourceQuota enforcement for SparkApplication resources.",
              "type": "boolean",
              "default": false
            }
          }
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "name": {
              "type": "string"
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "rbac": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "labels": {
          "description": "Extra labels for webhook pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "description": "Extra annotations for webhook pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "env": {
          "description": "Environment variables for webhook containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "envFrom": {
          "description": "Environment variable sources for webhook containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "volumeMounts": {
          "description": "Volume mounts for webhook containers.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "securityContext": {
          "description": "Security context for webhook containers.",
          "type": "object"
        },
        "sidecars": {
          "description": "Sidecar containers for webhook pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "volumes": {
          "description": "Volumes for webhook pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "nodeSelector": {
          "description": "Node selector for webhook pods.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "affinity": {
          "description": "Affinity for webhook pods.",
          "type": "object",
          "additionalProperties": {
            "type": "object"
          }
        },
        "tolerations": {
          "description": "List of node taints to tolerate for webhook pods.",
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "priorityClassName": {
          "description": "Priority class for webhook pods.",
          "type": "string"
        },
        "resources": {
          "description": "Pod resource requests and limits for webhook pods.",
          "type": "object"
        },
        "podSecurityContext": {
          "description": "Security context for webhook pods.",
          "type": "object"
        }
      }
    },
    "spark": {
      "type": "object",
      "properties": {
        "jobNamespaces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "default"
          ]
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "name": {
              "type": "string"
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "rbac": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "annotations": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "prometheus": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "enable": {
              "type": "boolean",
              "default": true
            },
            "port": {
              "type": "integer",
              "default": 8080
            },
            "portName": {
              "type": "string",
              "default": "metrics"
            },
            "prefix": {
              "type": "string"
            }
          }
        },
        "podMonitor": {
          "type": "object",
          "properties": {
            "create": {
              "type": "boolean",
              "default": true
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "podMetricsEndpoint": {
              "type": "object",
              "properties": {
                "schema": {
                  "type": "string",
                  "default": "http"
                },
                "interval": {
                  "type": "string",
                  "default": "5s"
                }
              }
            }
          }
        }
      }
    }
  }
}